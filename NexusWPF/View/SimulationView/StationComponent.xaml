<UserControl x:Class="NexusWPF.View.SimulationView.StationComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NexusWPF.View.SimulationView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Width="200" BorderThickness="1" BorderBrush="LightGray" Padding="5">
        <StackPanel Orientation="Vertical" Margin="5">
            <TextBlock Text="{Binding Value.StationID}" Foreground="White"/>
        </StackPanel>
    </Border>
</UserControl>
