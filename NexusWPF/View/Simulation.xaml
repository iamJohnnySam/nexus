<UserControl x:Class="NexusWPF.View.Simulation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NexusWPF.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="1" Text="{Binding SelectedSimulation}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5" Height="30" Width="300" />

        <Button Grid.Row="2" x:Name="btnStartSimulation" Height="30" Width="150" Command="{Binding StartSimulation}">Start Simulation</Button>
    </Grid>
</UserControl>
