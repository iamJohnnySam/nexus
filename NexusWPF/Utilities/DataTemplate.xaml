<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:NexusWPF.ViewModel"
                    xmlns:view="clr-namespace:NexusWPF.View">

    <DataTemplate DataType="{x:Type vm:HomeVM}">
        <view:Home />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:ProjectsVM}">
        <view:Projects />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:DocumentationVM}">
        <view:Documentation />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:FATVM}">
        <view:FAT />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:TasksVM}">
        <view:Tasks />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:SimulationVM}">
        <view:Simulation />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:ReviewVM}">
        <view:Review />
    </DataTemplate>


</ResourceDictionary>