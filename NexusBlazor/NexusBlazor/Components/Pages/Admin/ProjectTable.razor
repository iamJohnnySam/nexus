@inject IManager manager

<table class="table-auto w-full mb-6 border">
    <thead class="bg-gray-200">
        <tr>
            <th class="p-2">ID</th>
            <th class="p-2">Name</th>
            <th class="p-2">Customer</th>
            <th class="p-2">Product</th>
            <th class="p-2">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Projects)
        {
            <tr class="border-b">
                <td class="p-2">@project.ProjectId</td>
                <td class="p-2">@project.ProjectName</td>
                <td class="p-2">@project.Customer?.CustomerName</td>
                <td class="p-2">@project.Product?.ProductName</td>
                <td class="p-2">
                    <button class="bg-blue-500 px-2 py-1 rounded" @onclick="() => EditProject(project)">Edit</button>
                    <button class="bg-red-500 px-2 py-1 rounded ml-2" @onclick="() => DeleteProject(project.ProjectId)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- CRUD Form -->
<div class="p-6 rounded shadow">
    <h3 class="text-xl font-semibold mb-4">@((IsEditing ? "Edit" : "Create") + " Project")</h3>

    <div class="mb-4">
        <label class="block mb-1">Project Name</label>
        <input class="w-full p-2 border rounded" @bind="EditingProject.ProjectName" />
    </div>

    <div class="mb-4">
        <label class="block mb-1">Customer</label>
        <select class="w-full p-2 border rounded" @bind="EditingProject.CustomerId">
            @foreach (var customer in Customers)
            {
                <option value="@customer.CustomerId">@customer.CustomerName</option>
            }
        </select>
    </div>

    <div class="mb-4">
        <label class="block mb-1">Product</label>
        <select class="w-full p-2 border rounded" @bind="EditingProject.ProductId">
            @foreach (var product in Products)
            {
                <option value="@product.ProductId">@product.ProductName</option>
            }
        </select>
    </div>

    <div class="flex gap-4">
        <button class="bg-green-600 text-white px-4 py-2 rounded" @onclick="SaveProject">@((IsEditing ? "Update" : "Create"))</button>
        @if (IsEditing)
        {
            <button class="bg-gray-500 text-white px-4 py-2 rounded" @onclick="CancelEdit">Cancel</button>
        }
    </div>
</div>

@code {
    private List<Project> Projects = new();
    private List<Customer> Customers = new();
    private List<Product> Products = new();

    private Project EditingProject;
    private bool IsEditing = false;

    protected override void OnInitialized()
    {
        EditingProject = manager.GetNewProject();
        LoadData();
    }

    private void LoadData()
    {
        Projects = manager.GetAllProjects().Result;
        Customers = manager.GetAllCustomers().Result;
        Products = manager.GetAllProducts().Result;
    }

    private void CancelEdit()
    {
        EditingProject = manager.GetNewProject();
        IsEditing = false;
    }

    private void EditProject(Project project)
    {
        EditingProject = new Project
        {
            ProjectId = project.ProjectId,
            ProjectName = project.ProjectName,
            CustomerId = project.CustomerId,
            ProductId = project.ProductId,
            DesignCode = project.DesignCode,
            Priority = project.Priority,
            POStatus = project.POStatus
        };
        IsEditing = true;
    }



    private void SaveProject()
    {
        if (IsEditing)
        {
            manager.UpdateProject(EditingProject);
        }
        else
        {
            manager.InsertProject(EditingProject);
        }
        LoadData();
        CancelEdit();
    }

    private void DeleteProject(int id)
    {
        manager.DeleteProject(id);
        LoadData();
    }

}
