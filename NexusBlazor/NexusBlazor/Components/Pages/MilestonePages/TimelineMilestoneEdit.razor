@using ProjectManager.Tools
@inject Manager manager
@inject IJSRuntime JS

<div class="card p-3" style="background-color: transparent;">
    <h5>@(SelectedMilestone?.MilestoneId == 0 ? "Add New Milestone" : "Edit Milestone")</h5>

    <EditForm Model="@SelectedMilestone" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Milestone Name</label>
            <InputText class="form-control" @bind-Value="SelectedMilestone.Name" />
            <ValidationMessage For="@(() => SelectedMilestone.Name)" />
        </div>

        <div class="mb-3">
            <div class="row">
                <div class="col">
                    <label class="form-label">Planned Start Date</label>
                    <InputDate class="form-control" @bind-Value="SelectedMilestone.PlannedStartDate" />
                </div>
                <div class="col">
                    <label class="form-label">Planned Required Days</label>
                    <InputNumber class="form-control" @bind-Value="SelectedMilestone.PlannedRequiredDays" />
                </div>
                <div class="col">
                    <label class="form-label">Planned End Date (Optional)</label>
                    <InputDate class="form-control" @bind-Value="PlannedEndDate" />
                </div>
            </div>
        </div>

        <div class="mb-3">
            <div class="row">
                <div class="col">
                    <label class="form-label">Actual Start Date</label>
                    <InputDate class="form-control" @bind-Value="SelectedMilestone.StartDate" />
                </div>
                <div class="col">
                    <label class="form-label">Actual Required Days</label>
                    <InputNumber class="form-control" @bind-Value="SelectedMilestone.RequiredDays" />
                </div>
                <div class="col">
                    <label class="form-label">Actual End Date (Optional)</label>
                    <InputDate class="form-control" @bind-Value="EndDate" />
                </div>
            </div>
        </div>

        <div class="mb-3">
            <div class="row">
                <div class="col">
                    <label class="form-label">Dependent Milestone</label>
                    <InputSelect class="form-control" @bind-Value="DependencyId">
                        <option value=0>-- None --</option>
                        @foreach (var m in FilteredMilestones)
                        {
                            <option value="@m.MilestoneId">@m.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="col">
                    <label class="form-label">Dependency Type</label>
                    <InputSelect class="form-control" @bind-Value="SelectedMilestone.DependencyType">
                        @foreach (var d in Enum.GetValues<DependencyType>())
                        {
                            <option value="@d">@d</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-1">
                    <button type="button" class="btn btn-secondary" @onclick="RemoveDependency">Remove</button>
                </div>
            </div>  
        </div>

        <div class="mb-3">
            <div class="row">
                <div class="col">
                    <label class="form-label">Engineer</label>
                    <InputSelect class="form-control" @bind-Value="SelectedMilestone.EngineerId">
                        <option value="">-- Select Engineer --</option>
                        @foreach (var e in Engineers)
                        {
                            <option value="@e.EmployeeId">@e.EmployeeName</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-1">
                    <button type="button" class="btn btn-secondary" @onclick="RemoveEmployee">Remove</button>
                </div>
                <div class="col-2">
                    <InputCheckbox class="form-check-input" @bind-Value="SelectedMilestone.IsCompleted" />
                    <label class="form-check-label">Completed</label>
                </div>
                <div class="col">
                    <label class="form-label">Project Stage</label>
                    <InputSelect class="form-control" @bind-Value="SelectedMilestone.ProjectStageId">
                        @foreach (ProjectStage d in ProjectStages)
                        {
                            <option value="@d.ProjectStageId">@d.ProjectStageName</option>
                        }
                    </InputSelect>
                </div>
            </div>
        </div>

       
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Save</button>
            <button type="button" class="btn btn-secondary" @onclick="DeleteMilestone">Delete</button>
            <button type="button" class="btn btn-secondary" @onclick="CloseBox">Close</button>
        </div>
    </EditForm>
</div>

@code {
    private List<Employee> Engineers = [];
    private List<Milestone> FilteredMilestones = [];
    private List<ProjectStage> ProjectStages = [];

    [Parameter]
    public required Milestone SelectedMilestone { get; set; }

    [Parameter]
    public EventCallback OnMilestoneChange { get; set; }

    private DateTime endDate = DateTime.Today;
    public DateTime EndDate
    {
        get 
        { 
            return endDate; 
        }
        set 
        { 
            endDate = value;
            try{
                SelectedMilestone.RequiredDays = CalendarLogic.GetWorkDays(SelectedMilestone.StartDate, value);
            }
            catch (ArgumentException)
            {
                SelectedMilestone.RequiredDays = 1;
            }

        }
    }

    private DateTime plannedEndDate = DateTime.Today;
    public DateTime PlannedEndDate
    {
        get 
        { 
            return plannedEndDate; 
        }
        set
        {
            plannedEndDate = value;
            try{
                SelectedMilestone.PlannedRequiredDays = CalendarLogic.GetWorkDays(SelectedMilestone.PlannedStartDate, value);
            }
            catch (ArgumentException)
            {
                SelectedMilestone.PlannedRequiredDays = 1;
            }

        }
    }

    private int dependencyId;
    public int DependencyId
    {
        get { return dependencyId; }
        set { 
            dependencyId = value;
            SelectedMilestone.DependentMilestoneId = value;
            Milestone temp = manager.GetMilestoneById(value).Result;
            if(temp is not null)
            {
                SelectedMilestone.StartDate = CalendarLogic.AddWorkDays(temp.StartDate, temp.RequiredDays);
                SelectedMilestone.PlannedStartDate = CalendarLogic.AddWorkDays(temp.PlannedStartDate, temp.PlannedRequiredDays);
            }
        }
    }

    bool syncPlanActual = false;


    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        dependencyId = SelectedMilestone.DependentMilestoneId;
        endDate = SelectedMilestone.EndDate ?? SelectedMilestone.StartDate;
        plannedEndDate = SelectedMilestone.PlannedEndDate ?? SelectedMilestone.PlannedStartDate;

        if ((SelectedMilestone.PlannedStartDate == SelectedMilestone.StartDate) && (SelectedMilestone.PlannedRequiredDays == SelectedMilestone.RequiredDays) && (SelectedMilestone.PlannedStartDate > DateTime.Now))
        {
            syncPlanActual = true;
        }
        else
        {
            syncPlanActual = false;
        }

        List<Milestone> Milestones = await manager.GetAllMilestones();
        FilteredMilestones = Milestones
            .Where(m => m.ProjectId == SelectedMilestone.ProjectId && m.MilestoneId != SelectedMilestone.MilestoneId)
            .ToList();
    }

    private async Task HandleSubmit()
    {
        if (SelectedMilestone.MilestoneId == 0)
        {
            await manager.InsertMilestone(SelectedMilestone);
        }
        else
        {
            await manager.UpdateMilestone(SelectedMilestone);
        }

        await LoadData();
        ResetForm();
    }

    private async Task LoadData()
    {
        Engineers = await manager.GetAllEmployees();
        ProjectStages = await manager.GetAllProjectStages();
    }

    private async void DeleteMilestone()
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this milestone?");
        if (!confirm) return;

        await manager.DeleteMilestone(SelectedMilestone);
        await LoadData();
        ResetForm();
    }

    private async void CloseBox()
    {
        ResetForm();
    }

    private void RemoveEmployee()
    {
        SelectedMilestone.EngineerId = 0;
    }
    private void RemoveDependency()
    {
        SelectedMilestone.DependentMilestoneId = 0;
    }

    private async void ResetForm()
    {
        SelectedMilestone = new Milestone
        {
            ProjectId = manager.CurrentProject.ProjectId,
            Name = string.Empty,
            StartDate = DateTime.Today,
            PlannedStartDate = DateTime.Today,
            RequiredDays = 1,
            DependencyType = DependencyType.FinishToStart
        };
        await OnMilestoneChange.InvokeAsync();
    }

}
