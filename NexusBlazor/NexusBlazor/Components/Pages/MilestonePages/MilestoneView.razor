@page "/trackers"
@inject Manager manager
@rendermode InteractiveServer

<PageTitle>Overview & Milestone Tracker</PageTitle>

<div class="row" style="padding-top: 20px; width: 100vw">
    <div class="col">
        <h2 class="text-2xl font-semibold mb-4" style="padding-left: 30px;">Overview & Milestone Tracker</h2>
    </div>
    <div class="col-3">
        
    </div>
    <div class="col-2">
        
    </div>
</div>
<hr style="border-top: 1px solid white" />

<div class="row" style="width: 100vw">
    <div class="col-1" style="@GetMenuStyle("Project")" @onclick="selectMenuProject">
        Project
    </div>
    <div class="col-1" style="@GetMenuStyle("Timeline")" @onclick="selectMenuTimeline">
        Timeline
    </div>
    <div class="col-1" style="@GetMenuStyle("Resources")" @onclick="selectMenuResources">
        Resources
    </div>
</div>
<hr style="border-top: 1px solid white" />

@if (menuSelected == "Project")
{
    <ProjectTracker />
}
else if (menuSelected == "Timeline")
{
    <TimelineTracker />
}
else if (menuSelected == "Resources")
{
    <ResourceTracker />
}

@code{
    private string menuSelected = "Project";

    private void selectMenuProject()
    {
        menuSelected = "Project";
    }

    private void selectMenuResources()
    {
        menuSelected = "Resources";
    }

    private void selectMenuTimeline()
    {
        menuSelected = "Timeline";
    }

    private string GetMenuStyle(string selectedItem)
    {
        if(selectedItem == menuSelected)
        {
            return "text-align: center; background-color: darkred;";
        }
        else
        {
            return "text-align: center";
        }
    }

}