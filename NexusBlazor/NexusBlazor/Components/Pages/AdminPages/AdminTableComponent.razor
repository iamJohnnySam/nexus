<div class="project-card border border-white rounded-4 p-3 mb-3 text-white"
     style="background-color: rgba(255, 255, 255, 0.05); cursor: pointer;"
     @onclick="HandleClick">
    <h5 class="mb-2">@Table</h5>
</div>

@code {
    [Parameter]
    public required string Table { get; set; }

    [Parameter]
    public EventCallback<string> OnTableSelected { get; set; }

    private async Task HandleClick()
    {
        await OnTableSelected.InvokeAsync(Table);
    }
}
